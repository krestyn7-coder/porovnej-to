{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/styles.css",
      "destination": "/web/styles.css"
    },
    {
      "source": "/app.js",
      "destination": "/web/app.js"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/web/manifest.webmanifest"
    },
    {
      "source": "/icon.svg",
      "destination": "/web/icon.svg"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/web/$1"
    }
  ]
}
